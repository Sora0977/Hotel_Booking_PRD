// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  emailVerified Boolean  @default(false)
  passwordHash  String?
  firstName     String?
  lastName      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  roles UserRole[]

  avatarId String?
  avatar   ImageAsset? @relation("UserAvatar", fields: [avatarId], references: [id], onDelete: SetNull)

  provider   AuthProvider @default(LOCAL)
  providerId String?      @unique

  sessions         AuthSession[]
  verifyTokens     EmailVerifyToken[]
  resetTokens      PasswordResetToken[]
  ownedHotels      Hotel[]
  hotelMemberships HotelMember[]        @relation("UserHotelMemberships")
  galleries        ImageGallery[]
  folderGalleries  FolderGallery[]
  reviews          Review[]
  news             News[]
  banners          Banner[]
  contactMessages  ContactMessage[]
  handledContacts  ContactMessage[]     @relation("ContactHandledBy")
  bookingGuests    BookingGuest[]
  checkInsHandled  CheckIn[]            @relation("CheckInHandledBy")
  notifications    Notification[]
}

model Hotel {
  id          String  @id @default(cuid())
  name        String
  address     String?
  city        String?
  country     String?
  description String?

  status HotelStatus @default(DRAFT)

  ownerId  String
  owner    User      @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  bookings Booking[]

  roomTypes           RoomType[]
  rooms               Room[]
  members             HotelMember[]
  images              HotelImage[]
  reviews             Review[]
  commissionPackageId String?
  commissionPackage   CommissionPackage? @relation(fields: [commissionPackageId], references: [id], onDelete: SetNull)
  policies            HotelPolicy[]
  promotions          Promotion[]
  inventories Inventory[]
  notifications Notification[]

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model HotelMember {
  hotelId String
  userId  String

  hotel Hotel @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  user  User  @relation("UserHotelMemberships", fields: [userId], references: [id])

  @@id([hotelId, userId])
  @@index([userId])
}

model Role {
  id          String           @id @default(cuid())
  name        String           @unique
  description String?
  users       UserRole[]
  permissions RolePermission[]
}

model Permission {
  id          String            @id @default(cuid())
  name        String            @unique
  description String?
  roles       RolePermission[]
  apiPolicies ApiActionPolicy[]
}

model UserRole {
  user   User   @relation(fields: [userId], references: [id])
  userId String
  role   Role   @relation(fields: [roleId], references: [id])
  roleId String

  @@id([userId, roleId])
}

model RolePermission {
  role         Role       @relation(fields: [roleId], references: [id])
  roleId       String
  permission   Permission @relation(fields: [permissionId], references: [id])
  permissionId String

  @@id([roleId, permissionId])
}

model AuthSession {
  id          String       @id @default(cuid())
  userId      String
  jti         String       @unique
  refreshHash String
  provider    AuthProvider @default(LOCAL)

  userAgent String?
  ip        String?
  createdAt DateTime  @default(now())
  expiresAt DateTime
  revokedAt DateTime?
  revokedBy String?
  reason    String?
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model EmailVerifyToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([tokenHash])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @db.VarChar(64)
  usedAt    DateTime?
  expiresAt DateTime
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([tokenHash])
  @@index([expiresAt])
}

model ApiAction {
  id          String            @id @default(cuid())
  key         String            @unique // ví dụ: "hotel.update"
  description String?
  enabled     Boolean           @default(true)
  mode        PolicyMode        @default(ANY)
  policies    ApiActionPolicy[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ApiActionPolicy {
  action       ApiAction  @relation(fields: [actionId], references: [id])
  actionId     String
  permission   Permission @relation(fields: [permissionId], references: [id])
  permissionId String

  @@id([actionId, permissionId])
}

model ImageAsset {
  id        String @id @default(cuid())
  // publicId là định danh xoá trên Cloudinary (bắt buộc để delete)
  publicId  String @unique
  url       String
  secureUrl String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Liên kết 1-1 cho avatar user (optional)
  userAvatarOf User[] @relation("UserAvatar")

  // Liên kết N-N có payload cho Hotel/RoomType/Location qua các bảng nối
}

model ImageGallery {
  id        String @id @default(cuid())
  publicId  String @unique
  url       String
  secureUrl String

  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  userId    String
  folderId  String
  folder    FolderGallery @relation(fields: [folderId], references: [id], onDelete: Cascade)
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model FolderGallery {
  id         String         @id @default(cuid())
  folderName String         @unique
  userId     String
  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  galleries  ImageGallery[]
}

model HotelImage {
  id      String @id @default(cuid())
  hotelId String
  url     String
  hotel   Hotel  @relation(fields: [hotelId], references: [id], onDelete: Cascade)
}

model RoomType {
  id              String  @id @default(cuid())
  hotelId         String
  name            String
  price_per_night Decimal @db.Decimal(12, 2)
  max_guests      Int
  description     String?

  hotel Hotel @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  rooms        Room[]
  amenities    RoomTypeAmenity[]
  images       RoomTypeImage[]
  bookingItems BookingItem[]
  inventories  Inventory[]

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([hotelId, name])
  @@index([hotelId])
}

model Amenity {
  id        String  @id @default(cuid())
  key       String  @unique // vd: "Wifi", "AirVent", "Coffee"
  label     String // vd: "Wi-Fi", "Máy lạnh", "Cà phê miễn phí"
  sortOrder Int     @default(0)
  isActive  Boolean @default(true)

  roomTypes RoomTypeAmenity[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RoomTypeAmenity {
  typeId    String
  amenityId String

  roomType RoomType @relation(fields: [typeId], references: [id], onDelete: Cascade)
  amenity  Amenity  @relation(fields: [amenityId], references: [id], onDelete: Cascade)

  @@id([typeId, amenityId])
  @@index([amenityId])
}

model RoomTypeImage {
  id         String   @id @default(cuid())
  roomTypeId String
  url        String
  roomType   RoomType @relation(fields: [roomTypeId], references: [id], onDelete: Cascade)
}

model Room {
  id         String @id @default(cuid())
  hotelId    String
  roomTypeId String

  code  String // ví dụ: "101", "A-1203"
  floor String?
  note  String?

  status      RoomStatus      @default(ACTIVE)
  cleanStatus RoomCleanStatus @default(CLEAN)

  hotel    Hotel    @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  roomType RoomType @relation(fields: [roomTypeId], references: [id], onDelete: Cascade)

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([hotelId, code])
  @@index([hotelId, roomTypeId])
}

model Inventory {
  id String @id @default(cuid())

  hotelId    String
  roomTypeId String

  date DateTime @db.Date

  totalRooms     Int     @default(0)
  availableRooms Int     @default(0)
  stopSell       Boolean @default(false)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  hotel    Hotel    @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  roomType RoomType @relation(fields: [roomTypeId], references: [id], onDelete: Cascade)

  @@unique([roomTypeId, hotelId, date])
  @@index([hotelId, date])
  @@index([roomTypeId, date])
}

model Booking {
  id      String        @id @default(cuid())
  hotelId String
  userId  String?
  status  BookingStatus @default(PENDING)

  checkIn  DateTime
  checkOut DateTime

  guestName  String
  guestEmail String?
  guestPhone String?

  discountAmount Decimal? @db.Decimal(12, 2)
  totalAmount            Decimal @default(0) @db.Decimal(12, 2)
  note                   String?
  hotel                  Hotel   @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  commissionRateSnapshot Float? // commission tại thời điểm tạo booking
  commissionAmount       Int? // số tiền hoa hồng (VND)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items         BookingItem[]
  payments      Payment[]
  review        Review?
  guests        BookingGuest[]
  notifications Notification[]
  checkInRecord CheckIn?
  promotionId String?
  promotion   Promotion? @relation(fields: [promotionId], references: [id], onDelete: SetNull)
  @@index([hotelId])
  @@index([userId])
}

model CheckIn {
  id        String  @id @default(cuid())
  bookingId String  @unique
  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  checkedInAt     DateTime @default(now())
  checkedInBy     String? // userId nhân viên/owner thực hiện
  checkedInByUser User?    @relation("CheckInHandledBy", fields: [checkedInBy], references: [id], onDelete: SetNull)

  note String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BookingGuest {
  id        String  @id @default(cuid())
  bookingId String
  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  // (tuỳ chọn) nếu người ở cùng cũng có tài khoản User trong hệ thống
  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  fullName String
  email    String?
  phone    String?

  // thông tin hay gặp khi check-in khách sạn (tuỳ bạn bật/tắt)
  dateOfBirth DateTime?
  gender      Gender?
  idNumber    String? // CCCD/Passport
  nationality String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([bookingId])
  @@index([userId])
}

model BookingItem {
  id         String @id @default(cuid())
  bookingId  String
  roomTypeId String
  quantity   Int

  unitPrice Decimal @db.Decimal(12, 2)
  lineTotal Decimal @db.Decimal(12, 2)

  booking  Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  roomType RoomType @relation(fields: [roomTypeId], references: [id])

  @@index([bookingId])
  @@index([roomTypeId])
}

model Review {
  id String @id @default(cuid())

  hotelId String
  hotel   Hotel  @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  bookingId String  @unique
  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  rating  Int // 1..5
  title   String?
  content String?

  isHidden  Boolean   @default(false)
  deletedAt DateTime?

  images ReviewImage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([hotelId, createdAt])
  @@index([userId, createdAt])
}

model ReviewImage {
  id       String @id @default(cuid())
  reviewId String
  url      String

  review Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@index([reviewId])
}

model News {
  id          String     @id @default(cuid())
  title       String
  slug        String     @unique
  summary     String?
  content     String? // nếu bạn lưu HTML/markdown
  status      NewsStatus @default(DRAFT)
  publishedAt DateTime?

  // audit
  createdById String?
  createdBy   User?   @relation(fields: [createdById], references: [id], onDelete: SetNull)

  images NewsImage[]

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([status, publishedAt])
  @@index([createdAt])
}

model NewsImage {
  id     String @id @default(cuid())
  newsId String
  url    String
  news   News   @relation(fields: [newsId], references: [id], onDelete: Cascade)

  @@index([newsId])
}

model Banner {
  id       String  @id @default(cuid())
  title    String?
  subtitle String?

  link     String?
  linkType BannerLinkType @default(URL)

  position Int     @default(0)
  isActive Boolean @default(true)

  startAt DateTime?
  endAt   DateTime?

  images BannerImage[]

  createdById String?
  createdBy   User?   @relation(fields: [createdById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, position])
}

model BannerImage {
  id       String @id @default(cuid())
  bannerId String
  url      String

  banner Banner @relation(fields: [bannerId], references: [id], onDelete: Cascade)

  @@index([bannerId])
}

enum ContactStatus {
  NEW
  IN_PROGRESS
  RESOLVED
  SPAM
}

model ContactMessage {
  id String @id @default(cuid())

  // Người gửi (public)
  name    String
  email   String?
  phone   String?
  subject String?
  message String

  // Metadata chống spam / trace
  ip        String?
  userAgent String?

  status ContactStatus @default(NEW)

  // (Tuỳ chọn) nếu user đã đăng nhập và bạn muốn lưu
  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  // Admin xử lý
  handledById String?
  handledBy   User?   @relation("ContactHandledBy", fields: [handledById], references: [id], onDelete: SetNull)

  // Ghi chú nội bộ
  note String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, createdAt])
  @@index([email])
  @@index([phone])
}

enum BannerLinkType {
  URL
  HOTEL
  NEWS
}

enum NewsStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum PaymentProvider {
  VNPAY
}

model Payment {
  id       String          @id @default(cuid())
  provider PaymentProvider
  status   PaymentStatus   @default(INIT)

  bookingId String
  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  // Amount lưu theo đơn vị VND (giống booking.totalAmount)
  amount Decimal @db.Decimal(12, 2)

  // vnp_TxnRef: mã giao dịch phía merchant (bạn tự sinh)
  merchantTxnRef String @unique

  // VNPAY fields (lưu những cái cần đối soát)
  vnpTransactionNo  String? // vnp_TransactionNo
  bankCode          String? // vnp_BankCode
  payDate           DateTime? // vnp_PayDate (parse từ YYYYMMDDHHmmss)
  responseCode      String? // vnp_ResponseCode
  transactionStatus String? // vnp_TransactionStatus

  // checksum/audit
  secureHashAlg String? // sha512
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  events PaymentEvent[]

  @@index([bookingId])
  @@index([provider, status])
}

model PaymentEvent {
  id        String  @id @default(cuid())
  paymentId String
  payment   Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  type      String // "RETURN" | "IPN" | "QUERYDR" | "REFUND"
  payload   Json
  createdAt DateTime @default(now())

  @@index([paymentId])
}

model CommissionPackage {
  id             String  @id @default(cuid())
  code           String  @unique
  name           String
  description    String?
  commissionRate Float // 0.1 = 10%
  isActive       Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  hotels Hotel[]
}

model HotelPolicy {
  id      String     @id @default(cuid())
  hotelId String
  type    PolicyType
  title   String
  content String
  enabled Boolean    @default(true)
  order   Int        @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  hotel Hotel @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  @@unique([hotelId, type])
  @@index([hotelId])
}

model Notification {
  id String @id @default(cuid())

  // Người nhận thông báo (owner / staff)
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Khách sạn liên quan
  hotelId String?
  hotel   Hotel? @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  // Booking liên quan (đơn đặt phòng mới)
  bookingId String?
  booking   Booking? @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  type NotificationType

  title   String
  message String

  // Dùng cho redirect frontend
  actionUrl String?

  isRead  Boolean  @default(false)
  readAt  DateTime?

  createdAt DateTime @default(now())

  @@index([userId, isRead])
  @@index([hotelId])
  @@index([bookingId])
}
model Promotion {
  id String @id @default(cuid())

  code String @unique // VD: HOTEL10, SUMMER2026
  name String
  description String?

  discountType DiscountType
  discountValue Float // % hoặc số tiền VND

  maxDiscountAmount Decimal? @db.Decimal(12, 2) // trần giảm
  minBookingAmount Decimal? @db.Decimal(12, 2) // đơn tối thiểu

  totalUsageLimit Int? // tổng lượt dùng
  usedCount Int @default(0)

  perUserLimit Int? // mỗi user dùng tối đa

  startAt DateTime
  endAt DateTime

  isActive Boolean @default(true)

  // Phạm vi áp dụng
  hotelId String?
  hotel Hotel? @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  bookings Booking[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([code])
  @@index([hotelId])
}

// ==================== ENUM ====================
enum NotificationType {
  NEW_BOOKING        // Có đơn đặt phòng mới
  BOOKING_CANCELLED  // Huỷ đơn
  BOOKING_CONFIRMED  // Xác nhận đơn
  CHECK_IN           // Khách check-in
  CHECK_OUT
  PAYMENT_SUCCESS
  PAYMENT_FAILED
  SYSTEM
}
enum DiscountType {
  PERCENT // giảm %
  FIXED   // giảm tiền cố định
}
enum PolicyType {
  CHECKIN
  CANCELLATION
  PAYMENT
  CHILDREN
  PET
  SMOKING
  GENERAL
}

enum AuthProvider {
  LOCAL
  GOOGLE
}

enum PolicyMode {
  ANY // chỉ cần 1 quyền trong danh sách
  ALL // cần đủ toàn bộ quyền
}

enum ImageKind {
  AVATAR // avatar user
  COVER // ảnh bìa/cover
  GALLERY // ảnh trong bộ sưu tập
  DOC // tài liệu/biên lai nếu cần
}

enum HotelMemberRole {
  OWNER
  MANAGER
  STAFF
}

enum HotelStatus {
  DRAFT // mới tạo, chưa public/hoạt động
  ACTIVE // đang hoạt động
  SUSPENDED // bị khoá/tạm dừng
  ARCHIVED // lưu trữ/ngừng kinh doanh
}

enum RoomStatus {
  ACTIVE
  INACTIVE
  MAINTENANCE
}

enum RoomCleanStatus {
  CLEAN
  DIRTY
  INSPECT
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  CHECKED_IN
  COMPLETED
  NO_SHOW
}

enum PaymentStatus {
  INIT // vừa tạo attempt, đã build paymentUrl
  PENDING // chờ IPN xác nhận (sau redirect)
  SUCCEEDED
  FAILED
  CANCELED
  REFUND_PENDING
  REFUNDED
}

enum PackageType {
  FREE // miễn phí
  SUBSCRIPTION // trả phí định kỳ (tháng/quý/năm)
  SLOT // theo slot
  PAY_PER_BOOKING // trả theo booking (commission)
}

enum BillingCycle {
  MONTH
  QUARTER
  YEAR
}

enum Gender {
  MALE
  FEMALE
  OTHER
}
