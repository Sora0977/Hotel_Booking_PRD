            NODE_ENV: development
        ports: ['4000:4000']
        depends_on: [db, redis]
    web:
        build:
            context: ./apps/web
            dockerfile: Dockerfile
        environment:
            NODE_ENV: development
            NEXT_PUBLIC_API_URL: http://localhost:4000
        ports: ['3000:3000']
        depends_on: [api]
volumes:
    db_data: {}
</file>

